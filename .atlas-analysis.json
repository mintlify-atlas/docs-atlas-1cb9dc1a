  "keyFeatures": [
    "Layer-based compositing with 16 blend modes",
    "Non-destructive transforms (position, rotation, scale, flip)",
    "Comprehensive filter system (HSL, blur, sharpen, levels, gradient map)",
    "Shape layers with fill and stroke styling",
    "Layer masks and clipping masks",
    "Sprite sheet packing and pixel-art tools",
    "Multi-format I/O (PNG, JPEG, WebP, GIF, PSD)",
    "Bucket fill tool with contiguous/non-contiguous modes",
    "Full document serialization",
    "Pure WASM - no Canvas API or DOM dependencies"
  ],
